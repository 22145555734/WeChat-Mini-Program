<view class="page">
  <view class="header">
    <text class="title">{{categoryName}}</text>
    <text class="count">共 {{bookList.length}} 本</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 图书列表 -->
  <view wx:elif="{{bookList.length > 0}}" class="list">
    <view
      class="book-item"
      wx:for="{{bookList}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <image class="cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="info">
        <view class="name">{{item.title}}</view>
        <view class="author">作者：{{item.author}}</view>
        <view class="price-row">
          <text class="price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空数据 -->
  <view wx:else class="empty">
    <text>该分类下暂无图书</text>
  </view>
</view>
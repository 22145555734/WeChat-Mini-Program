<view class="page">
  <view class="content">
    <!-- 左侧分类栏 -->
    <scroll-view class="category-sidebar" scroll-y>
      <view 
        class="category-item {{currentId === item.id ? 'active' : ''}}"
        wx:for="{{categories}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧图书列表 -->
    <scroll-view class="book-list" scroll-y>
      <view 
        class="book-item" 
        wx:for="{{currentBooks}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="goDetail"
      >
        <image class="cover" src="{{item.cover}}" mode="aspectFill"></image>
        <view class="info">
          <view class="book-title">{{item.title}}</view>
          <view class="author">{{item.author}}</view>
          <view class="price-row">
            <text class="price">¥{{item.price}}</text>
          </view>
        </view>
      </view>

      <!-- 空数据提示 -->
      <view wx:if="{{currentBooks.length === 0}}" class="empty-tip">
        <text>该分类下暂无图书</text>
      </view>
    </scroll-view>
  </view>
</view>
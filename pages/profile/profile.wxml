<view class="page">
  <!-- 用户信息卡片 -->
  <view class="user-card" bindtap="handleUserCardTap">
    <!-- 头像区域 -->
    <view class="avatar">
      <!-- 1. 如果有头像链接，显示图片 -->
      <image wx:if="{{userInfo && userInfo.avatar}}" src="{{userInfo.avatar}}" mode="aspectFill" class="avatar-image"></image>
      
      <!-- 2. 如果没头像，显示文字首字母或默认文字 -->
      <text wx:else class="avatar-text">
        {{userInfo ? userInfo.username.charAt(0).toUpperCase() : '登录'}}
      </text>
    </view>

    <!-- 用户信息 -->
    <view class="user-info">
      <!-- 昵称区域：优先显示 nickname，没有则显示 username -->
      <view class="nickname">
        {{userInfo ? (userInfo.nickname || userInfo.username) : '点击登录'}}
      </view>
      
      <view class="tips">
        <text wx:if="{{userInfo}}" class="user-id">ID: {{userInfo.id}}</text>
        <text wx:else class="login-tip">点击登录享更多权益</text>
      </view>
    </view>

    <!-- 退出按钮 -->
    <view wx:if="{{userInfo}}" class="logout-btn" catchtap="onLogout">
      <text>退出</text>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <navigator url="/pages/order-list/order-list" class="more">
        全部订单
        <text class="arrow">></text>
      </navigator>
    </view>

    <view class="order-tabs">
      <view class="order-item">
        <view class="order-icon pending">
          <text class="iconfont">💳</text>
        </view>
        <text class="order-label">待付款</text>
      </view>
      <view class="order-item">
        <view class="order-icon paid">
          <text class="iconfont">📦</text>
        </view>
        <text class="order-label">待收货</text>
      </view>
      <view class="order-item">
        <view class="order-icon all">
          <text class="iconfont">📋</text>
        </view>
        <text class="order-label">全部订单</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="section">
    <view class="menu-list">
      <view class="menu-item" bindtap="goToAddress">
        <view class="menu-left">
          <text class="menu-icon">📍</text>
          <text class="menu-text">收货地址</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item" bindtap="clearStorage">
        <view class="menu-left">
          <text class="menu-icon">🗑️</text>
          <text class="menu-text">清空缓存</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item">
        <view class="menu-left">
          <text class="menu-icon">ℹ️</text>
          <text class="menu-text">关于我们</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>图书商城 v1.0.0</text>
  </view>
</view>
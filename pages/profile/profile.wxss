.page {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #2b7cff 0%, #1677ff 100%);
  padding: 60rpx 40rpx 80rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  /* 关键：允许头像溢出容器，实现悬浮效果 */
  overflow: visible; 
}

/* 头像容器 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%; /* 圆形容器 */
  background: #fff; /* 白色背景，防止图片加载慢时难看 */
  border: 4rpx solid #fff; /* 白色边框 */
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden; /* 关键：隐藏超出圆形的部分，让图片变圆 */
  flex-shrink: 0; /* 防止在空间不足时被压缩 */
}

/* 头像图片样式 - 新增 */
.avatar-image {
  width: 100%;
  height: 100%;
}

/* 头像文字样式 */
.avatar-text {
  color: #2b7cff; /* 文字颜色改为蓝色，在白色背景上更清晰 */
  font-size: 48rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
}

.nickname {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tips {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 未登录时的提示文字样式 */
.login-tip {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 500;
}

/* 已登录时的用户ID样式 */
.user-id {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.logout-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: -40rpx 24rpx 24rpx; /* 负边距实现卡片上移覆盖蓝色背景 */
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
  z-index: 2; /* 确保白色卡片层级在头像之上（如果需要头像被遮挡）或之下 */
}

.section:last-of-type {
  margin-top: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.more {
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.arrow {
  font-size: 24rpx;
}

/* 订单标签 */
.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.order-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-icon.pending {
  background: #fff5f5;
}

.order-icon.paid {
  background: #f6ffed;
}

.order-icon.all {
  background: #f0f5ff;
}

.iconfont {
  font-size: 36rpx;
}

.order-label {
  font-size: 26rpx;
  color: #666;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #fa5151;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

/* 功能菜单 */
.menu-list {
  margin: -10rpx -30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.version {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: 60rpx;
}